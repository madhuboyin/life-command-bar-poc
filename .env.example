# Shared
NODE_ENV=development
AUTH_SECRET=replace_with_32_plus_char_secret
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
API_AUTH_TOKEN_SECRET=replace_with_32_plus_char_secret

# API
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lcb_poc
REDIS_URL=redis://localhost:6379
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
TOKEN_ENCRYPTION_KEY=replace_with_long_random_secret
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:4000/api/gmail/oauth/callback
GMAIL_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/settings
GMAIL_OAUTH_STATE_SECRET=replace_with_state_secret
ALLOW_DEV_USER_HEADER_AUTH=false
ADMIN_USER_EMAILS=admin@example.com

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXTAUTH_URL=http://localhost:3000
