generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ObligationType {
  BILL
  SUBSCRIPTION
  RENEWAL
  COMMITMENT
}

enum ObligationSource {
  MANUAL
  EMAIL
  DOCUMENT
  INFERRED
}

enum ObligationStatus {
  DRAFT
  ACTIVE
  POSTPONED
  RESOLVED
  IGNORED
}

enum EffortLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  SCHEDULED
  TRIGGERED
  CANCELLED
}

enum UploadStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum ImportSourceType {
  MANUAL
  EMAIL
  DOCUMENT
}

enum ImportSourceSubtype {
  EMAIL_FORWARD
  GMAIL_READONLY
  FILE_UPLOAD
  COMMAND_CAPTURE
}

enum ImportParseStatus {
  RECEIVED
  PARTIAL
  READY
  NEEDS_CONFIRMATION
  REJECTED
  FAILED
}

enum ExternalProvider {
  GOOGLE_GMAIL
}

enum ExternalAccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}

enum ExternalSyncStatus {
  IDLE
  RUNNING
  COMPLETED
  ERROR
}

enum ExternalMessageIngestionStatus {
  PROCESSED
  DUPLICATE_SUPPRESSED
  ROUTED_TO_REVIEW
  SKIPPED
  ERROR
}

enum SubscriptionLifecycleState {
  DISCOVERED
  TRIALING
  ACTIVE
  RENEWING
  PRICE_CHANGED
  CANCELING
  CANCELED
  ENDED
  INACTIVE
  UNKNOWN
}

enum SubscriptionBillingPeriod {
  MONTHLY
  YEARLY
  QUARTERLY
  WEEKLY
  UNKNOWN
}

enum SubscriptionAutoRenewStatus {
  ON
  OFF
  UNKNOWN
}

enum SubscriptionConfidenceBand {
  HIGH
  MEDIUM
  LOW
}

enum SubscriptionInsightType {
  PRICE_INCREASE
  RENEWAL_UPCOMING
  UNUSED_RISK
  LOW_CONFIDENCE
  CANCELLATION_CONFIRMED
  DUPLICATE_SUBSCRIPTION
  PLAN_MISMATCH
  UNKNOWN_STATE
}

enum SubscriptionInsightSeverity {
  HIGH
  MEDIUM
  LOW
}

enum SubscriptionRecommendationType {
  KEEP
  REVIEW
  CANCEL
  DOWNGRADE
  CONFIRM
  IGNORE
}

enum SubscriptionEvidenceSourceType {
  GMAIL
  UPLOAD
  COMMAND
  MANUAL
  PREDICTION
}

enum SubscriptionEvidenceSourceSubtype {
  WELCOME_EMAIL
  RENEWAL_EMAIL
  RECEIPT_EMAIL
  CANCELLATION_EMAIL
  MANUAL_CONFIRMATION
  REVIEW_CONFIRMATION
}

enum SubscriptionEvidenceReferenceType {
  IMPORT_SOURCE
  OBLIGATION
  PREDICTION
  MEMORY_PATTERN
  EXTERNAL_MESSAGE
}

enum SubscriptionLifecycleEventType {
  DISCOVERED
  TRIAL_STARTED
  ACTIVATED
  RENEWAL_DETECTED
  RECEIPT_CAPTURED
  PRICE_CHANGED
  AUTO_RENEW_ON
  AUTO_RENEW_OFF
  CANCELLATION_DETECTED
  CANCELED
  REACTIVATED
  MERGED
  CORRECTED
}

enum SubscriptionPriceType {
  INTRO
  RECURRING
  CHARGED
}

enum FeedbackType {
  ACCEPTED
  IGNORED
  MODIFIED
  COMPLETED
  POSTPONED
  REJECTED
  NOT_RELEVANT
  WRONG_INFO
  DONT_SHOW_AGAIN
}

enum ResolutionConfidence {
  HIGH
  MEDIUM
  LOW
}

enum GuidedJourneyType {
  BILL
  SUBSCRIPTION
  RENEWAL
  COMMITMENT
}

enum GuidedJourneyStatus {
  ACTIVE
  COMPLETED
  DISMISSED
  ABANDONED
}

enum GuidedJourneyInputType {
  NONE
  SINGLE_SELECT
}

enum GuidedJourneyEventType {
  JOURNEY_CREATED
  JOURNEY_RESUMED
  STEP_SELECTED_OPTION
  STEP_COMPLETED
  STEP_ADVANCED
  STEP_REVERSED
  JOURNEY_COMPLETED
  JOURNEY_ABANDONED
  JOURNEY_DISMISSED
}

enum FlowSourceType {
  DAILY_PULSE
  TODAY_FEED
  DASHBOARD
  OBLIGATION_DETAIL
  AUTO_FLOW
  FOCUS_MODE
}

enum FlowSessionState {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum FocusSessionState {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum FocusSessionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  POSTPONED
  DISMISSED
  SKIPPED
}

enum MemoryEntityType {
  VENDOR
  SUBSCRIPTION
  CATEGORY
  OBLIGATION_TEMPLATE
}

enum MemoryPatternType {
  RECURRING_OBLIGATION
  USER_BEHAVIOR
  TIMING_PATTERN
}

enum MemoryEventSourceType {
  INGESTION
  OBLIGATION_ACTION
  GUIDED_JOURNEY
  FEEDBACK
  FOCUS_MODE
  SYSTEM_REBUILD
}

enum PredictionType {
  RECURRING_NEXT_OCCURRENCE
  UPCOMING_ATTENTION
  WORKLOAD_WINDOW
  MISSING_EXPECTED_OBLIGATION
}

enum PredictionReferenceType {
  MEMORY_PATTERN
  MEMORY_ENTITY
  OBLIGATION
  VENDOR
}

enum PredictionStatus {
  ACTIVE
  CONFIRMED
  DISMISSED
  EXPIRED
  PROMOTED_TO_OBLIGATION
}

enum PredictionConfidenceBand {
  HIGH
  MEDIUM
  LOW
}

enum DailyPulseItemStatus {
  PENDING
  OPENED_GUIDED
  COMPLETED
  POSTPONED
  DISMISSED
}

enum OutcomeSourceContext {
  TODAY_FEED
  DASHBOARD_INSIGHT
  DAILY_PULSE
  GUIDED_MODE
  OBLIGATION_DETAIL
}

enum OutcomeType {
  FOLLOWED_RECOMMENDATION
  CHOSE_DIFFERENT_OPTION
  HELPFUL
  NOT_HELPFUL
  COMPLETED_SUCCESSFULLY
  POSTPONED_INTENTIONALLY
  DISMISSED_NOT_RELEVANT
  ABANDONED
  RECOMMENDATION_MISMATCH
}

enum AutoFlowTriggerType {
  INGESTION_TRIGGER
  URGENCY_TRIGGER
  PATTERN_TRIGGER
  REMINDER_TRIGGER
}

enum AutoFlowStateStatus {
  READY
  SUGGESTED
  ACCEPTED
  DISMISSED
}

enum ZeroInputAutonomyTier {
  OBSERVE_ONLY
  PREPARE_ONLY
  SAFE_AUTOMATION
}

enum ZeroInputDecision {
  EXECUTED
  REVIEW
  APPROVAL_REQUIRED
  SUPPRESSED
}

enum ZeroInputActionType {
  CREATE_DRAFT_FROM_INGESTION
  PROMOTE_RECURRING_PREDICTION
  AUTO_CREATE_REMINDER
  PREPARE_AUTO_FLOW
  SUPPRESS_DUPLICATE
  AUTO_REFRESH_SURFACES
}

enum ZeroInputApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  UNDONE
}

enum ScopeType {
  PERSONAL
  HOUSEHOLD
}

enum HouseholdMemberRole {
  OWNER
  MEMBER
}

enum HouseholdMemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum HouseholdInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum MetricTimeBucket {
  DAY
  WEEK
  MONTH
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  emailVerified DateTime? @map("email_verified")
  image    String?
  timezone String  @default("America/New_York")
  locale   String?

  accounts Account[]
  sessions Session[]

  obligations         Obligation[] @relation("ObligationOwner")
  assignedObligations Obligation[] @relation("ObligationAssignedTo")
  createdObligations  Obligation[] @relation("ObligationCreatedBy")
  lastHandledObligations Obligation[] @relation("ObligationLastHandledBy")
  reminders           Reminder[]
  feedbackEvents      FeedbackEvent[]
  auditEvents         AuditEvent[]
  uploads             Upload[]
  importSources       ImportSource[]
  resolutionRuns      ResolutionRun[]
  guidedJourneys      GuidedJourney[]
  guidedJourneyEvents GuidedJourneyEvent[]
  dailyPulseStates    DailyPulseState[]
  dailyPulseItemStates DailyPulseItemState[]
  flowSessions        FlowSession[]
  outcomeFeedback     OutcomeFeedback[]
  autoFlowStates      AutoFlowState[]
  focusSessions       FocusSession[]
  focusSessionItems   FocusSessionItem[]
  memoryEntities      MemoryEntity[]
  memoryPatterns      MemoryPattern[]
  memoryContext       MemoryContext?
  memoryEvents        MemoryEvent[]
  predictions         Prediction[]
  zeroInputPolicy     ZeroInputPolicy?
  autonomyDecisions   AutonomyDecision[]
  householdsCreated   Household[]      @relation("HouseholdCreatedBy")
  householdMemberships HouseholdMember[]
  householdInvitesSent HouseholdInvite[] @relation("HouseholdInviteSentBy")
  externalAccountConnections ExternalAccountConnection[]
  externalMessageIngestions  ExternalMessageIngestion[]
  subscriptionsOwned         SubscriptionRegistry[] @relation("SubscriptionOwner")
  assignedSubscriptions      SubscriptionRegistry[] @relation("SubscriptionAssignedTo")
  createdSubscriptions       SubscriptionRegistry[] @relation("SubscriptionCreatedBy")
  lastHandledSubscriptions   SubscriptionRegistry[] @relation("SubscriptionLastHandledBy")
  subscriptionInsights       SubscriptionInsight[]
  subscriptionRecommendations SubscriptionRecommendation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String
  provider          String
  providerAccountId String @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId], map: "uniq_accounts_provider_provider_account_id")
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

model Session {
  id String @id @default(cuid())

  sessionToken String @unique @map("session_token")
  userId String @map("user_id")
  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token], map: "uniq_verification_tokens_identifier_token")
  @@map("verification_tokens")
}

model Household {
  id String @id @default(cuid())

  name String
  slug String? @unique

  createdByUserId String @map("created_by_user_id")
  createdByUser   User   @relation("HouseholdCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  members           HouseholdMember[]
  invites           HouseholdInvite[]
  obligations       Obligation[]
  subscriptions     SubscriptionRegistry[]
  predictions       Prediction[]
  reminders         Reminder[]
  autonomyDecisions AutonomyDecision[]
  auditEvents       AuditEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdByUserId], map: "idx_households_created_by_user_id")
  @@map("households")
}

model HouseholdMember {
  id String @id @default(cuid())

  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   HouseholdMemberRole   @default(MEMBER)
  status HouseholdMemberStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([householdId, userId], map: "uniq_household_members_household_user")
  @@index([userId, status], map: "idx_household_members_user_status")
  @@index([householdId, status], map: "idx_household_members_household_status")
  @@map("household_members")
}

model HouseholdInvite {
  id String @id @default(cuid())

  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  invitedEmail String @map("invited_email")

  invitedByUserId String @map("invited_by_user_id")
  invitedByUser   User   @relation("HouseholdInviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  role   HouseholdMemberRole @default(MEMBER)
  token  String              @unique
  status HouseholdInviteStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  @@index([householdId, status], map: "idx_household_invites_household_status")
  @@index([invitedEmail, status], map: "idx_household_invites_email_status")
  @@map("household_invites")
}

model Obligation {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation("ObligationOwner", fields: [userId], references: [id], onDelete: Cascade)

  scopeType ScopeType @default(PERSONAL) @map("scope_type")
  householdId String? @map("household_id")
  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  assignedToUserId String? @map("assigned_to_user_id")
  assignedToUser   User?   @relation("ObligationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  createdByUserId String? @map("created_by_user_id")
  createdByUser   User?   @relation("ObligationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  lastHandledByUserId String? @map("last_handled_by_user_id")
  lastHandledByUser   User?   @relation("ObligationLastHandledBy", fields: [lastHandledByUserId], references: [id], onDelete: SetNull)

  type        ObligationType
  title       String
  description String?
  vendor      String?

  amount   Decimal? @db.Decimal(12, 2)
  currency String?  @db.VarChar(3)

  dueDate    DateTime? @map("due_date")
  recurrence String?

  source ObligationSource
  status ObligationStatus @default(DRAFT)

  subscriptionId String? @map("subscription_id")
  subscription   SubscriptionRegistry? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  importSourceId String?      @map("import_source_id")
  importSource   ImportSource? @relation(fields: [importSourceId], references: [id], onDelete: SetNull)

  confidenceScore Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  urgencyScore    Decimal @default(0.0) @map("urgency_score") @db.Decimal(7, 4)
  importanceScore Decimal @default(0.0) @map("importance_score") @db.Decimal(7, 4)

  effortLevel EffortLevel @default(MEDIUM) @map("effort_level")
  impactLevel ImpactLevel @default(MEDIUM) @map("impact_level")

  lastShownAt DateTime? @map("last_shown_at")
  lastActedAt DateTime? @map("last_acted_at")

  reminders           Reminder[]
  feedbackEvents      FeedbackEvent[]
  auditEvents         AuditEvent[]
  resolutionRuns      ResolutionRun[]
  guidedJourneys      GuidedJourney[]
  guidedJourneyEvents GuidedJourneyEvent[]
  dailyPulseItemStates DailyPulseItemState[]
  flowSessionsAsCurrent FlowSession[] @relation("FlowSessionCurrentObligation")
  outcomeFeedback     OutcomeFeedback[]
  autoFlowStates      AutoFlowState[]
  focusSessionItems   FocusSessionItem[]
  promotedPredictions Prediction[] @relation("PredictionPromotedObligation")
  autonomyDecisions   AutonomyDecision[]
  externalMessageIngestions ExternalMessageIngestion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status], map: "idx_obligations_user_id_status")
  @@index([userId, dueDate], map: "idx_obligations_user_id_due_date")
  @@index([userId, type], map: "idx_obligations_user_id_type")
  @@index([userId, lastShownAt], map: "idx_obligations_user_id_last_shown_at")
  @@index([userId, vendor], map: "idx_obligations_user_id_vendor")
  @@index([scopeType], map: "idx_obligations_scope_type")
  @@index([householdId, status], map: "idx_obligations_household_id_status")
  @@index([assignedToUserId, status], map: "idx_obligations_assigned_to_user_id_status")
  @@index([createdByUserId], map: "idx_obligations_created_by_user_id")
  @@index([lastHandledByUserId], map: "idx_obligations_last_handled_by_user_id")
  @@index([importSourceId], map: "idx_obligations_import_source_id")
  @@index([subscriptionId], map: "idx_obligations_subscription_id")
  @@map("obligations")
}

model SubscriptionRegistry {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation("SubscriptionOwner", fields: [userId], references: [id], onDelete: Cascade)

  scopeType ScopeType @default(PERSONAL) @map("scope_type")
  householdId String? @map("household_id")
  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  assignedToUserId String? @map("assigned_to_user_id")
  assignedToUser   User?   @relation("SubscriptionAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  createdByUserId String? @map("created_by_user_id")
  createdByUser   User?   @relation("SubscriptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  lastHandledByUserId String? @map("last_handled_by_user_id")
  lastHandledByUser   User?   @relation("SubscriptionLastHandledBy", fields: [lastHandledByUserId], references: [id], onDelete: SetNull)

  vendorName          String @map("vendor_name")
  vendorNormalizedKey String @map("vendor_normalized_key")
  planName            String? @map("plan_name")
  subscriptionTitle   String @map("subscription_title")
  category            String?

  lifecycleState SubscriptionLifecycleState @default(DISCOVERED) @map("lifecycle_state")
  billingPeriod   SubscriptionBillingPeriod @default(UNKNOWN) @map("billing_period")

  recurringPrice    Decimal? @map("recurring_price") @db.Decimal(12, 2)
  currency          String?  @db.VarChar(3)
  introPrice        Decimal? @map("intro_price") @db.Decimal(12, 2)
  amountLastCharged Decimal? @map("amount_last_charged") @db.Decimal(12, 2)

  autoRenewStatus SubscriptionAutoRenewStatus @default(UNKNOWN) @map("auto_renew_status")

  trialEndDate               DateTime? @map("trial_end_date")
  nextRenewalDate            DateTime? @map("next_renewal_date")
  lastChargedDate            DateTime? @map("last_charged_date")
  cancellationEffectiveDate  DateTime? @map("cancellation_effective_date")

  sourceConfidenceScore Decimal                    @default(0.0) @map("source_confidence_score") @db.Decimal(5, 4)
  sourceConfidenceBand  SubscriptionConfidenceBand @default(LOW) @map("source_confidence_band")

  obligations     Obligation[]
  evidence        SubscriptionEvidence[]
  lifecycleEvents SubscriptionLifecycleEvent[]
  priceHistory    SubscriptionPriceHistory[]
  insights        SubscriptionInsight[]
  recommendation  SubscriptionRecommendation?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, lifecycleState], map: "idx_subscription_registry_user_lifecycle")
  @@index([userId, vendorNormalizedKey], map: "idx_subscription_registry_user_vendor_key")
  @@index([scopeType], map: "idx_subscription_registry_scope_type")
  @@index([householdId, lifecycleState], map: "idx_subscription_registry_household_lifecycle")
  @@index([assignedToUserId, lifecycleState], map: "idx_subscription_registry_assigned_lifecycle")
  @@index([createdByUserId], map: "idx_subscription_registry_created_by")
  @@index([lastHandledByUserId], map: "idx_subscription_registry_last_handled_by")
  @@map("subscription_registry")
}

model SubscriptionInsight {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String               @map("subscription_id")
  subscription   SubscriptionRegistry @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  insightType SubscriptionInsightType @map("insight_type")
  title       String
  description String
  severity    SubscriptionInsightSeverity
  confidenceScore Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  metadata Json?
  recommendedAction String @map("recommended_action")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([subscriptionId, insightType], map: "uniq_subscription_insights_subscription_type")
  @@index([userId, insightType], map: "idx_subscription_insights_user_type")
  @@index([subscriptionId, severity], map: "idx_subscription_insights_subscription_severity")
  @@map("subscription_insights")
}

model SubscriptionRecommendation {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String               @unique @map("subscription_id")
  subscription   SubscriptionRegistry @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  recommendationType SubscriptionRecommendationType @map("recommendation_type")
  reason             String
  confidenceScore    Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  supportingInsights Json? @map("supporting_insights")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, recommendationType], map: "idx_subscription_recommendations_user_type")
  @@map("subscription_recommendations")
}

model SubscriptionEvidence {
  id String @id @default(cuid())

  subscriptionId String               @map("subscription_id")
  subscription   SubscriptionRegistry @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  sourceType    SubscriptionEvidenceSourceType
  sourceSubType SubscriptionEvidenceSourceSubtype? @map("source_sub_type")

  referenceType SubscriptionEvidenceReferenceType @map("reference_type")
  referenceId   String                            @map("reference_id")

  signalSummary Json? @map("signal_summary")
  confidenceScore Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  observedAt DateTime @map("observed_at")

  lifecycleEvents SubscriptionLifecycleEvent[] @relation("LifecycleEventEvidence")
  priceHistory    SubscriptionPriceHistory[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([subscriptionId, observedAt], map: "idx_subscription_evidence_subscription_observed")
  @@index([sourceType, sourceSubType], map: "idx_subscription_evidence_source")
  @@index([referenceType, referenceId], map: "idx_subscription_evidence_reference")
  @@map("subscription_evidence")
}

model SubscriptionLifecycleEvent {
  id String @id @default(cuid())

  subscriptionId String               @map("subscription_id")
  subscription   SubscriptionRegistry @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  eventType SubscriptionLifecycleEventType @map("event_type")

  previousState SubscriptionLifecycleState? @map("previous_state")
  nextState     SubscriptionLifecycleState? @map("next_state")
  eventDate     DateTime? @map("event_date")

  metadata Json?

  sourceEvidenceId String? @map("source_evidence_id")
  sourceEvidence   SubscriptionEvidence? @relation("LifecycleEventEvidence", fields: [sourceEvidenceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([subscriptionId, createdAt], map: "idx_subscription_lifecycle_events_subscription_created")
  @@index([eventType, createdAt], map: "idx_subscription_lifecycle_events_type_created")
  @@index([sourceEvidenceId], map: "idx_subscription_lifecycle_events_source_evidence")
  @@map("subscription_lifecycle_events")
}

model SubscriptionPriceHistory {
  id String @id @default(cuid())

  subscriptionId String               @map("subscription_id")
  subscription   SubscriptionRegistry @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  priceType SubscriptionPriceType @map("price_type")
  amount Decimal @db.Decimal(12, 2)
  currency String @db.VarChar(3)
