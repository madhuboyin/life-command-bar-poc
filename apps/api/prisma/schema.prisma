  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp], map: "idx_observability_events_timestamp")
  @@index([eventType, timestamp], map: "idx_observability_events_event_type_timestamp")
  @@index([userId, timestamp], map: "idx_observability_events_user_id_timestamp")
  @@index([householdId, timestamp], map: "idx_observability_events_household_id_timestamp")
  @@index([traceId], map: "idx_observability_events_trace_id")
  @@index([correlationId], map: "idx_observability_events_correlation_id")
  @@index([entityType, entityId], map: "idx_observability_events_entity")
  @@map("observability_events")
}

model MetricSnapshot {
  id String @id @default(cuid())

  metricType String @map("metric_type")
  value Decimal @db.Decimal(14, 4)
  dimension Json?
  dimensionKey String @default("all") @map("dimension_key")

  timeBucket MetricTimeBucket @map("time_bucket")
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([metricType, timeBucket, timestamp, dimensionKey], map: "uniq_metric_snapshots_metric_bucket_timestamp_dimension")
  @@index([timeBucket, timestamp], map: "idx_metric_snapshots_bucket_timestamp")
  @@index([metricType, timeBucket, timestamp], map: "idx_metric_snapshots_metric_bucket_timestamp")
  @@map("metric_snapshots")
}

model Upload {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName    String @map("file_name")
  fileType    String @map("file_type")
  fileSize    Int    @map("file_size")
  storagePath String @map("storage_path")

  status UploadStatus @default(UPLOADED)

  importSources ImportSource[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "idx_uploads_user_id_created_at")
  @@index([status], map: "idx_uploads_status")
  @@map("uploads")
}

model ImportSource {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    ImportSourceType
  subtype ImportSourceSubtype? @map("subtype")
  rawData Json?               @map("raw_data")
  rawText String?             @map("raw_text") @db.Text
  normalizedText String?      @map("normalized_text") @db.Text
  parseStatus ImportParseStatus @default(RECEIVED) @map("parse_status")
  parseConfidence Decimal @default(0.0) @map("parse_confidence") @db.Decimal(5, 4)
  parserVersion String? @map("parser_version")
  extractionSummary Json? @map("extraction_summary")
  contentHash String? @map("content_hash")

  uploadId String? @map("upload_id")
  upload   Upload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  obligations Obligation[]
  externalMessageIngestions ExternalMessageIngestion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "idx_import_sources_user_id_created_at")
  @@index([type], map: "idx_import_sources_type")
  @@index([subtype], map: "idx_import_sources_subtype")
  @@index([parseStatus], map: "idx_import_sources_parse_status")
  @@index([userId, contentHash], map: "idx_import_sources_user_id_content_hash")
  @@map("import_sources")
}

model ExternalAccountConnection {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider ExternalProvider
  providerAccountId String @map("provider_account_id")
  email String

  accessTokenEncrypted String? @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String? @map("refresh_token_encrypted") @db.Text
  scope String @db.Text

  status ExternalAccountStatus @default(ACTIVE)
  errorCode String? @map("error_code")
  errorMessage String? @map("error_message") @db.Text

  lastSyncedAt DateTime? @map("last_synced_at")
  lastHistoryId String? @map("last_history_id")
  lastProcessedMessageId String? @map("last_processed_message_id")
  lastProcessedMessageDate DateTime? @map("last_processed_message_date")
  lastSyncStatus ExternalSyncStatus? @map("last_sync_status")
  lastSyncCursor String? @map("last_sync_cursor")
  lastSyncWindowDays Int? @map("last_sync_window_days")
  lastSyncMatchedCount Int @default(0) @map("last_sync_matched_count")
  lastSyncIngestedCount Int @default(0) @map("last_sync_ingested_count")
  lastSyncDuplicateCount Int @default(0) @map("last_sync_duplicate_count")
  lastSyncErrorCount Int @default(0) @map("last_sync_error_count")

  autoSyncEnabled Boolean @default(false) @map("auto_sync_enabled")
  scanSubscriptions Boolean @default(true) @map("scan_subscriptions")
  scanBills Boolean @default(true) @map("scan_bills")
  scanRenewals Boolean @default(true) @map("scan_renewals")
  includeRecurringReceipts Boolean @default(false) @map("include_recurring_receipts")

  messages ExternalMessageIngestion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId], map: "uniq_external_connections_provider_account")
  @@unique([userId, provider], map: "uniq_external_connections_user_provider")
  @@index([userId, provider], map: "idx_external_connections_user_provider")
  @@index([userId, status], map: "idx_external_connections_user_status")
  @@index([provider, email], map: "idx_external_connections_provider_email")
  @@map("external_account_connections")
}

model ExternalMessageIngestion {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  externalConnectionId String @map("external_connection_id")
  externalConnection ExternalAccountConnection @relation(fields: [externalConnectionId], references: [id], onDelete: Cascade)

  provider ExternalProvider
  externalMessageId String @map("external_message_id")
  externalThreadId String? @map("external_thread_id")
  messageDate DateTime? @map("message_date")
  messageInternalDate DateTime? @map("message_internal_date")
  matchedQueryKey String? @map("matched_query_key")

  importSourceId String? @map("import_source_id")
  importSource ImportSource? @relation(fields: [importSourceId], references: [id], onDelete: SetNull)

  obligationId String? @map("obligation_id")
  obligation Obligation? @relation(fields: [obligationId], references: [id], onDelete: SetNull)

  status ExternalMessageIngestionStatus @default(PROCESSED)
  dedupeReason String? @map("dedupe_reason")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([externalConnectionId, externalMessageId], map: "uniq_external_messages_connection_message")
  @@index([userId, createdAt], map: "idx_external_messages_user_created")
  @@index([externalConnectionId, messageInternalDate], map: "idx_external_messages_connection_internal_date")
  @@index([provider, externalMessageId], map: "idx_external_messages_provider_message")
  @@map("external_message_ingestions")
}

model ResolutionRun {
  id String @id @default(cuid())

  userId String @map("user_id")
