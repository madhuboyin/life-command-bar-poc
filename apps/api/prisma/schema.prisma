generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ObligationType {
  BILL
  SUBSCRIPTION
  RENEWAL
  COMMITMENT
}

enum ObligationSource {
  MANUAL
  EMAIL
  DOCUMENT
  INFERRED
}

enum ObligationStatus {
  DRAFT
  ACTIVE
  POSTPONED
  RESOLVED
  IGNORED
}

enum EffortLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  SCHEDULED
  TRIGGERED
  CANCELLED
}

enum UploadStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum ImportSourceType {
  MANUAL
  EMAIL
  DOCUMENT
}

enum ImportSourceSubtype {
  EMAIL_FORWARD
  FILE_UPLOAD
  COMMAND_CAPTURE
}

enum ImportParseStatus {
  RECEIVED
  PARTIAL
  READY
  NEEDS_CONFIRMATION
  REJECTED
  FAILED
}

enum FeedbackType {
  ACCEPTED
  IGNORED
  MODIFIED
  COMPLETED
  POSTPONED
  REJECTED
  NOT_RELEVANT
  WRONG_INFO
  DONT_SHOW_AGAIN
}

enum ResolutionConfidence {
  HIGH
  MEDIUM
  LOW
}

enum GuidedJourneyType {
  BILL
  SUBSCRIPTION
  RENEWAL
  COMMITMENT
}

enum GuidedJourneyStatus {
  ACTIVE
  COMPLETED
  DISMISSED
  ABANDONED
}

enum GuidedJourneyInputType {
  NONE
  SINGLE_SELECT
}

enum GuidedJourneyEventType {
  JOURNEY_CREATED
  JOURNEY_RESUMED
  STEP_SELECTED_OPTION
  STEP_COMPLETED
  STEP_ADVANCED
  STEP_REVERSED
  JOURNEY_COMPLETED
  JOURNEY_ABANDONED
  JOURNEY_DISMISSED
}

enum FlowSourceType {
  DAILY_PULSE
  TODAY_FEED
  DASHBOARD
  OBLIGATION_DETAIL
  AUTO_FLOW
  FOCUS_MODE
}

enum FlowSessionState {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum FocusSessionState {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum FocusSessionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  POSTPONED
  DISMISSED
  SKIPPED
}

enum MemoryEntityType {
  VENDOR
  SUBSCRIPTION
  CATEGORY
  OBLIGATION_TEMPLATE
}

enum MemoryPatternType {
  RECURRING_OBLIGATION
  USER_BEHAVIOR
  TIMING_PATTERN
}

enum MemoryEventSourceType {
  INGESTION
  OBLIGATION_ACTION
  GUIDED_JOURNEY
  FEEDBACK
  FOCUS_MODE
  SYSTEM_REBUILD
}

enum PredictionType {
  RECURRING_NEXT_OCCURRENCE
  UPCOMING_ATTENTION
  WORKLOAD_WINDOW
  MISSING_EXPECTED_OBLIGATION
}

enum PredictionReferenceType {
  MEMORY_PATTERN
  MEMORY_ENTITY
  OBLIGATION
  VENDOR
}

enum PredictionStatus {
  ACTIVE
  CONFIRMED
  DISMISSED
  EXPIRED
  PROMOTED_TO_OBLIGATION
}

enum PredictionConfidenceBand {
  HIGH
  MEDIUM
  LOW
}

enum DailyPulseItemStatus {
  PENDING
  OPENED_GUIDED
  COMPLETED
  POSTPONED
  DISMISSED
}

enum OutcomeSourceContext {
  TODAY_FEED
  DASHBOARD_INSIGHT
  DAILY_PULSE
  GUIDED_MODE
  OBLIGATION_DETAIL
}

enum OutcomeType {
  FOLLOWED_RECOMMENDATION
  CHOSE_DIFFERENT_OPTION
  HELPFUL
  NOT_HELPFUL
  COMPLETED_SUCCESSFULLY
  POSTPONED_INTENTIONALLY
  DISMISSED_NOT_RELEVANT
  ABANDONED
  RECOMMENDATION_MISMATCH
}

enum AutoFlowTriggerType {
  INGESTION_TRIGGER
  URGENCY_TRIGGER
  PATTERN_TRIGGER
  REMINDER_TRIGGER
}

enum AutoFlowStateStatus {
  READY
  SUGGESTED
  ACCEPTED
  DISMISSED
}

enum ZeroInputAutonomyTier {
  OBSERVE_ONLY
  PREPARE_ONLY
  SAFE_AUTOMATION
}

enum ZeroInputDecision {
  EXECUTED
  REVIEW
  APPROVAL_REQUIRED
  SUPPRESSED
}

enum ZeroInputActionType {
  CREATE_DRAFT_FROM_INGESTION
  PROMOTE_RECURRING_PREDICTION
  AUTO_CREATE_REMINDER
  PREPARE_AUTO_FLOW
  SUPPRESS_DUPLICATE
  AUTO_REFRESH_SURFACES
}

enum ZeroInputApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  UNDONE
}

enum ScopeType {
  PERSONAL
  HOUSEHOLD
}

enum HouseholdMemberRole {
  OWNER
  MEMBER
}

enum HouseholdMemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum HouseholdInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  timezone String  @default("America/New_York")
  locale   String?

  obligations         Obligation[] @relation("ObligationOwner")
  assignedObligations Obligation[] @relation("ObligationAssignedTo")
  createdObligations  Obligation[] @relation("ObligationCreatedBy")
  lastHandledObligations Obligation[] @relation("ObligationLastHandledBy")
  reminders           Reminder[]
  feedbackEvents      FeedbackEvent[]
  auditEvents         AuditEvent[]
  uploads             Upload[]
  importSources       ImportSource[]
  resolutionRuns      ResolutionRun[]
  guidedJourneys      GuidedJourney[]
  guidedJourneyEvents GuidedJourneyEvent[]
  dailyPulseStates    DailyPulseState[]
  dailyPulseItemStates DailyPulseItemState[]
  flowSessions        FlowSession[]
  outcomeFeedback     OutcomeFeedback[]
  autoFlowStates      AutoFlowState[]
  focusSessions       FocusSession[]
  focusSessionItems   FocusSessionItem[]
  memoryEntities      MemoryEntity[]
  memoryPatterns      MemoryPattern[]
  memoryContext       MemoryContext?
  memoryEvents        MemoryEvent[]
  predictions         Prediction[]
  zeroInputPolicy     ZeroInputPolicy?
  autonomyDecisions   AutonomyDecision[]
  householdsCreated   Household[]      @relation("HouseholdCreatedBy")
  householdMemberships HouseholdMember[]
  householdInvitesSent HouseholdInvite[] @relation("HouseholdInviteSentBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Household {
  id String @id @default(cuid())

  name String
  slug String? @unique

  createdByUserId String @map("created_by_user_id")
  createdByUser   User   @relation("HouseholdCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  members           HouseholdMember[]
  invites           HouseholdInvite[]
  obligations       Obligation[]
  predictions       Prediction[]
  reminders         Reminder[]
  autonomyDecisions AutonomyDecision[]
  auditEvents       AuditEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdByUserId], map: "idx_households_created_by_user_id")
  @@map("households")
}

model HouseholdMember {
  id String @id @default(cuid())

  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   HouseholdMemberRole   @default(MEMBER)
  status HouseholdMemberStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([householdId, userId], map: "uniq_household_members_household_user")
  @@index([userId, status], map: "idx_household_members_user_status")
  @@index([householdId, status], map: "idx_household_members_household_status")
  @@map("household_members")
}

model HouseholdInvite {
  id String @id @default(cuid())

  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  invitedEmail String @map("invited_email")

  invitedByUserId String @map("invited_by_user_id")
  invitedByUser   User   @relation("HouseholdInviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  role   HouseholdMemberRole @default(MEMBER)
  token  String              @unique
  status HouseholdInviteStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  @@index([householdId, status], map: "idx_household_invites_household_status")
  @@index([invitedEmail, status], map: "idx_household_invites_email_status")
  @@map("household_invites")
}

model Obligation {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation("ObligationOwner", fields: [userId], references: [id], onDelete: Cascade)

  scopeType ScopeType @default(PERSONAL) @map("scope_type")
  householdId String? @map("household_id")
  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  assignedToUserId String? @map("assigned_to_user_id")
  assignedToUser   User?   @relation("ObligationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  createdByUserId String? @map("created_by_user_id")
  createdByUser   User?   @relation("ObligationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  lastHandledByUserId String? @map("last_handled_by_user_id")
  lastHandledByUser   User?   @relation("ObligationLastHandledBy", fields: [lastHandledByUserId], references: [id], onDelete: SetNull)

  type        ObligationType
  title       String
  description String?
  vendor      String?

  amount   Decimal? @db.Decimal(12, 2)
  currency String?  @db.VarChar(3)

  dueDate    DateTime? @map("due_date")
  recurrence String?

  source ObligationSource
  status ObligationStatus @default(DRAFT)

  importSourceId String?      @map("import_source_id")
  importSource   ImportSource? @relation(fields: [importSourceId], references: [id], onDelete: SetNull)

  confidenceScore Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  urgencyScore    Decimal @default(0.0) @map("urgency_score") @db.Decimal(7, 4)
  importanceScore Decimal @default(0.0) @map("importance_score") @db.Decimal(7, 4)

  effortLevel EffortLevel @default(MEDIUM) @map("effort_level")
  impactLevel ImpactLevel @default(MEDIUM) @map("impact_level")

  lastShownAt DateTime? @map("last_shown_at")
  lastActedAt DateTime? @map("last_acted_at")

  reminders           Reminder[]
  feedbackEvents      FeedbackEvent[]
  auditEvents         AuditEvent[]
  resolutionRuns      ResolutionRun[]
  guidedJourneys      GuidedJourney[]
  guidedJourneyEvents GuidedJourneyEvent[]
  dailyPulseItemStates DailyPulseItemState[]
  flowSessionsAsCurrent FlowSession[] @relation("FlowSessionCurrentObligation")
  outcomeFeedback     OutcomeFeedback[]
  autoFlowStates      AutoFlowState[]
  focusSessionItems   FocusSessionItem[]
  promotedPredictions Prediction[] @relation("PredictionPromotedObligation")
  autonomyDecisions   AutonomyDecision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status], map: "idx_obligations_user_id_status")
  @@index([userId, dueDate], map: "idx_obligations_user_id_due_date")
  @@index([userId, type], map: "idx_obligations_user_id_type")
  @@index([userId, lastShownAt], map: "idx_obligations_user_id_last_shown_at")
  @@index([userId, vendor], map: "idx_obligations_user_id_vendor")
  @@index([scopeType], map: "idx_obligations_scope_type")
  @@index([householdId, status], map: "idx_obligations_household_id_status")
  @@index([assignedToUserId, status], map: "idx_obligations_assigned_to_user_id_status")
  @@index([createdByUserId], map: "idx_obligations_created_by_user_id")
  @@index([lastHandledByUserId], map: "idx_obligations_last_handled_by_user_id")
  @@index([importSourceId], map: "idx_obligations_import_source_id")
  @@map("obligations")
}

model GuidedJourney {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  obligationId String     @map("obligation_id")
  obligation   Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  journeyType GuidedJourneyType   @map("journey_type")
  status      GuidedJourneyStatus @default(ACTIVE)

  currentStepKey   String? @map("current_step_key")
  currentStepIndex Int     @default(0) @map("current_step_index")
  recommendedPath  String? @map("recommended_path")
  summary          String?

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  steps  GuidedJourneyStep[]
  events GuidedJourneyEvent[]
  flowSessionsAsCurrent FlowSession[] @relation("FlowSessionCurrentJourney")
  outcomeFeedback OutcomeFeedback[]

  @@index([userId, status], map: "idx_guided_journeys_user_id_status")
  @@index([obligationId, status], map: "idx_guided_journeys_obligation_id_status")
  @@index([journeyType], map: "idx_guided_journeys_journey_type")
  @@map("guided_journeys")
}

model GuidedJourneyStep {
  id String @id @default(cuid())

  journeyId String        @map("journey_id")
  journey   GuidedJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  stepKey           String                 @map("step_key")
  title             String
  description       String
  whyItMatters      String                 @map("why_it_matters")
  inputType         GuidedJourneyInputType @default(NONE) @map("input_type")
  optionsJson       Json?                  @map("options_json")
  recommendedOption String?                @map("recommended_option")
  selectedOption    String?                @map("selected_option")
  isCompleted       Boolean                @default(false) @map("is_completed")
  completedAt       DateTime?              @map("completed_at")
  position          Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([journeyId, stepKey], map: "uniq_guided_journey_steps_journey_id_step_key")
  @@unique([journeyId, position], map: "uniq_guided_journey_steps_journey_id_position")
  @@index([journeyId], map: "idx_guided_journey_steps_journey_id")
  @@map("guided_journey_steps")
}

model GuidedJourneyEvent {
  id String @id @default(cuid())

  journeyId String        @map("journey_id")
  journey   GuidedJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  obligationId String?     @map("obligation_id")
  obligation   Obligation? @relation(fields: [obligationId], references: [id], onDelete: SetNull)

  eventType GuidedJourneyEventType @map("event_type")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([journeyId, createdAt], map: "idx_guided_journey_events_journey_id_created_at")
  @@index([userId, createdAt], map: "idx_guided_journey_events_user_id_created_at")
  @@index([obligationId], map: "idx_guided_journey_events_obligation_id")
  @@index([eventType], map: "idx_guided_journey_events_event_type")
  @@map("guided_journey_events")
}

model DailyPulseState {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date String @db.VarChar(10)

  openedAt DateTime? @map("opened_at")

  totalItems Int @default(0) @map("total_items")
  completedCount Int @default(0) @map("completed_count")
  postponedCount Int @default(0) @map("postponed_count")
  dismissedCount Int @default(0) @map("dismissed_count")
  isCompletedForNow Boolean @default(false) @map("is_completed_for_now")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items DailyPulseItemState[]

  @@unique([userId, date], map: "uniq_daily_pulse_state_user_id_date")
  @@index([userId, createdAt], map: "idx_daily_pulse_state_user_id_created_at")
  @@map("daily_pulse_states")
}

model FlowSession {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceType    FlowSourceType @map("source_type")
  sourceContext Json?          @map("source_context")

  currentObligationId String?      @map("current_obligation_id")
  currentObligation   Obligation?  @relation("FlowSessionCurrentObligation", fields: [currentObligationId], references: [id], onDelete: SetNull)

  currentJourneyId String?       @map("current_journey_id")
  currentJourney   GuidedJourney? @relation("FlowSessionCurrentJourney", fields: [currentJourneyId], references: [id], onDelete: SetNull)

  state FlowSessionState @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, state], map: "idx_flow_sessions_user_id_state")
  @@index([sourceType], map: "idx_flow_sessions_source_type")
  @@index([currentObligationId], map: "idx_flow_sessions_current_obligation_id")
  @@index([currentJourneyId], map: "idx_flow_sessions_current_journey_id")
  @@map("flow_sessions")
}

model FocusSession {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  durationMinutes Int @map("duration_minutes")
  sourceType FlowSourceType? @map("source_type")
  state FocusSessionState @default(ACTIVE)

  totalItems Int @default(0) @map("total_items")
  completedCount Int @default(0) @map("completed_count")
  postponedCount Int @default(0) @map("postponed_count")
  dismissedCount Int @default(0) @map("dismissed_count")
  skippedCount Int @default(0) @map("skipped_count")

  startedAt DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  abandonedAt DateTime? @map("abandoned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items FocusSessionItem[]

  @@index([userId, state, updatedAt], map: "idx_focus_sessions_user_state_updated_at")
  @@index([userId, createdAt], map: "idx_focus_sessions_user_created_at")
  @@map("focus_sessions")
}

model FocusSessionItem {
  id String @id @default(cuid())

  focusSessionId String @map("focus_session_id")
  focusSession   FocusSession @relation(fields: [focusSessionId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  obligationId String @map("obligation_id")
  obligation   Obligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  position Int
  status FocusSessionItemStatus @default(PENDING)
  whyIncluded String? @map("why_included")
  estimatedMinutes Int? @map("estimated_minutes")
  priorityScore Decimal? @db.Decimal(7, 4) @map("priority_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([focusSessionId, obligationId], map: "uniq_focus_session_items_session_obligation")
  @@unique([focusSessionId, position], map: "uniq_focus_session_items_session_position")
  @@index([userId, status], map: "idx_focus_session_items_user_status")
  @@index([obligationId], map: "idx_focus_session_items_obligation_id")
  @@map("focus_session_items")
}

model ZeroInputPolicy {
  id String @id @default(cuid())

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  modeEnabled  Boolean              @default(false) @map("mode_enabled")
  autonomyTier ZeroInputAutonomyTier @default(OBSERVE_ONLY) @map("autonomy_tier")

  allowRecurringPromotion Boolean @default(true) @map("allow_recurring_promotion")
  allowReminderAutocreate Boolean @default(true) @map("allow_reminder_autocreate")
  allowDuplicateSuppression Boolean @default(true) @map("allow_duplicate_suppression")
  allowAutoFlowPreparation Boolean @default(true) @map("allow_auto_flow_preparation")
  allowPredictionPromotion Boolean @default(true) @map("allow_prediction_promotion")

  requireApprovalForFinancialItems Boolean @default(true) @map("require_approval_for_financial_items")
  requireApprovalForLowConfidence Boolean @default(true) @map("require_approval_for_low_confidence")

  quietHoursStart String? @map("quiet_hours_start") @db.VarChar(5)
  quietHoursEnd   String? @map("quiet_hours_end") @db.VarChar(5)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_zero_input_policy_user_id")
  @@map("zero_input_policies")
}

model Prediction {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scopeType ScopeType @default(PERSONAL) @map("scope_type")
  householdId String? @map("household_id")
  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  predictionType PredictionType @map("prediction_type")
  referenceType  PredictionReferenceType @map("reference_type")
  referenceId    String @map("reference_id")

  title       String
  description String?

  predictedDate DateTime? @map("predicted_date")
  predictionWindowStart DateTime? @map("prediction_window_start")
  predictionWindowEnd DateTime? @map("prediction_window_end")

  confidenceScore Decimal @default(0.0) @map("confidence_score") @db.Decimal(5, 4)
  confidenceBand  PredictionConfidenceBand @default(LOW) @map("confidence_band")

  rationale Json?
  rationaleSummary String? @map("rationale_summary")

  status PredictionStatus @default(ACTIVE)

  promotedObligationId String? @map("promoted_obligation_id")
  promotedObligation   Obligation? @relation("PredictionPromotedObligation", fields: [promotedObligationId], references: [id], onDelete: SetNull)
  autonomyDecisions    AutonomyDecision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, predictionType, referenceType, referenceId], map: "uniq_predictions_user_type_reference")
  @@index([scopeType], map: "idx_predictions_scope_type")
  @@index([householdId, status, predictedDate], map: "idx_predictions_household_status_predicted_date")
  @@index([userId, status, predictedDate], map: "idx_predictions_user_status_predicted_date")
  @@index([userId, predictionWindowStart, predictionWindowEnd], map: "idx_predictions_user_window")
  @@index([userId, confidenceBand], map: "idx_predictions_user_confidence_band")
  @@index([promotedObligationId], map: "idx_predictions_promoted_obligation_id")
  @@map("predictions")
}

model MemoryEntity {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type MemoryEntityType
  name String
  normalizedKey String @map("normalized_key")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, type, normalizedKey], map: "uniq_memory_entities_user_type_key")
  @@index([userId, type], map: "idx_memory_entities_user_type")
  @@index([userId, updatedAt], map: "idx_memory_entities_user_updated_at")
  @@map("memory_entities")
}

